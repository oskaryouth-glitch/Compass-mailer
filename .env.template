# Copy this file to .env (for local dev) and fill in your values.
# In production (Vercel), set these as Environment Variables in your project settings.

# Apify token — get from https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI must match OAUTH_REDIRECT_URI below.
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For local dev:   http://localhost:3000/auth/callback
# For Vercel prod: https://<your-vercel-url>/auth/callback
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Neon Postgres connection string — https://console.neon.tech (use the "pooled" string)
DATABASE_URL=postgresql://...

# Random secret used to authenticate Vercel Cron Jobs. Generate with:
#   openssl rand -hex 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HTTP Basic Auth on the dashboard. If unset (local dev), auth is disabled.
# In production these should always be set. Anyone with these can view the
# dashboard, edit clients, and trigger sends — so pick something solid.
AUTH_USER=max
AUTH_PASSWORD=change-me-please
