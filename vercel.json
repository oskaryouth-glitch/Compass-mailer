{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/auth/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/monthly",
      "schedule": "0 9 1 * *"
    }
  ]
}
